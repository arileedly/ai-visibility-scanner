# DataForSEO API credentials
# Get these from https://app.dataforseo.com/api-access
DATAFORSEO_LOGIN=your_dataforseo_email@example.com
DATAFORSEO_PASSWORD=your_dataforseo_api_password

# Supabase — auto-injected by Supabase Edge Functions runtime (do not set manually)
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Supabase anon key — used in the frontend to call the Edge Function
SUPABASE_ANON_KEY=your_supabase_anon_key
